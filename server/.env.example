# ============================================================
# AI Content Platform - Biến môi trường mẫu
# Copy file này thành .env rồi điền giá trị thật.
# File .env KHÔNG commit lên git (đã nằm trong .gitignore).
# ============================================================

# --- Supabase / PostgreSQL -----------------------------------
# Lấy tại: Supabase Dashboard > Project Settings > Database > Connection string
#
# DATABASE_URL  = "Transaction pooler" (port 6543, có ?pgbouncer=true) -> runtime app
# DIRECT_URL    = "Direct connection"  (port 5432)                     -> prisma migrate/seed
DATABASE_URL="postgresql://user:password@host:6543/db?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/db"

# --- JWT / Auth ----------------------------------------------
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="1d"

# --- App ------------------------------------------------------
PORT=4500
CORS_ORIGIN="http://localhost:3002"

# --- Seed (tạo Organization + admin đầu tiên) -----------------
SEED_ORG_NAME="MyOrganization"
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="StrongPassword123"

# --- Redis / BullMQ (optional) --------------------------------
# Chạy: docker compose up -d  (từ thư mục gốc dự án)
REDIS_URL="redis://localhost:6379"

# --- LLM Provider (optional) ---------------------------------
# Điền OpenAI API key của bạn vào đây (sk-...)
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"
